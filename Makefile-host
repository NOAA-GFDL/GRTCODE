	$(CXX_COMPILE) -o $@ -c $<

device.o: ../utilities/src/device.c
	$(CXX_COMPILE) -o $@ -c $<

optics.o: ../utilities/src/optics.c
	$(CXX_COMPILE) -o $@ -c $<

parse_csv.o: ../utilities/src/parse_csv.c
	$(CXX_COMPILE) -o $@ -c $<

spectral_grid.o: ../utilities/src/spectral_grid.c
	$(CXX_COMPILE) -o $@ -c $<

utilities.o: ../utilities/src/utilities.c
	$(CXX_COMPILE) -o $@ -c $<

verbosity.o: ../utilities/src/verbosity.c
	$(CXX_COMPILE) -o $@ -c $<

