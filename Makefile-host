INCLUDES = -I../utilities/src -I../gas-optics/src -I../shortwave/src -I../longwave/src -I../clouds -I../framework/src -I../era5/src
CXX_COMPILE = $(CXX) $(CPPFLAGS) $(CFLAGS) $(INCLUDES)
MPICXX_COMPILE = $(MPICXX) $(CPPFLAGS) $(CFLAGS) $(INCLUDES)

all: libargparse.a libgrtcode_utilities.a libgas_optics.a \
     libshortwave.a liblongwave.a libclouds.a libera5.a era5.x

libargparse.a: argparse.o
	ar -rcs -o $@ $^

argparse.o: ../utilities/src/argparse.c
	$(CXX_COMPILE) -o $@ -c $<

libgrtcode_utilities.a: curtis_godson.o device.o optics.o parse_csv.o \
                        spectral_grid.o utilities.o verbosity.o
	ar -rcs -o $@ $^

