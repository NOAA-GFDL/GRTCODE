tips2017.o: ../gas-optics/src/tips2017.c
	$(CXX_COMPILE) -o $@ -c $<

water_vapor_continuum.o: ../gas-optics/src/water_vapor_continuum.c
	$(CXX_COMPILE) -o $@ -c $<

libshortwave.a: disort_shortwave.o rayleigh.o shortwave.o solar_flux.o
	ar -rcs -o $@ $^

disort_shortwave.o: ../shortwave/src/disort_shortwave.c
	$(CXX_COMPILE) -o $@ -c $<

rayleigh.o: ../shortwave/src/rayleigh.c
	$(CXX_COMPILE) -o $@ -c $<

shortwave.o: ../shortwave/src/shortwave.c
