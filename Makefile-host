	$(CXX_COMPILE) -o $@ -c $<

distribute.o: ../framework/src/distribute.c
	$(MPICXX_COMPILE) -o $@ -c $<

driver.o: ../framework/src/driver.c
	$(CXX_COMPILE) -fopenmp -o $@ -c $<

era5.x: driver.o distribute.o libera5.a libclouds.a liblongwave.a libshortwave.a \
        libgas_optics.a libgrtcode_utilities.a libargparse.a
	$(MPICXX) -fopenmp -o $@ $(LDFLAGS) $(NVCCLDFLAGS) $^ -lnetcdf -lcudart $(RPATH)

clean:
	rm -f *.o *.a *.x
