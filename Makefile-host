	$(CXX_COMPILE) -o $@ -c $<

libclouds.a: liquid_cloud_optics.o ice_cloud_optics.o incomplete_beta.o \
             netcdf_utils.o stochastic_clouds.o cloud_utils.o cloud_optics.o
	ar -rcs -o $@ $^

liquid_cloud_optics.o: ../clouds/liquid_cloud_optics.c
	$(CXX_COMPILE) -o $@ -c $<

ice_cloud_optics.o: ../clouds/ice_cloud_optics.c
	$(CXX_COMPILE) -o $@ -c $<

incomplete_beta.o: ../clouds/incomplete_beta.c
	$(CXX_COMPILE) -o $@ -c $<

netcdf_utils.o: ../clouds/netcdf_utils.c
