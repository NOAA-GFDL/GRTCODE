kernel_utils.o: ../gas-optics/src/kernel_utils.c
	$(CXX_COMPILE) -o $@ -c $<

kernels.o: ../gas-optics/src/kernels.c
	$(CXX_COMPILE) -o $@ -c $<

launch.o: ../gas-optics/src/launch.c
	$(CXX_COMPILE) -o $@ -c $<

molecules.o: ../gas-optics/src/molecules.c
	$(CXX_COMPILE) -o $@ -c $<

ozone_continuum.o: ../gas-optics/src/ozone_continuum.c
	$(CXX_COMPILE) -o $@ -c $<

parse_HITRAN_file.o: ../gas-optics/src/parse_HITRAN_file.c
	$(CXX_COMPILE) -o $@ -c $<

